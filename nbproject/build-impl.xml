<?xml version="1.0" encoding="UTF-8"?>
<project basedir=".." default="default" name="FlotaManagement-impl">
    <property file="nbproject/project.properties"/>
    <fail message="Please build using Ant 1.7.0 or higher.">
        <condition>
            <not>
                <antversion atleast="1.7.0"/>
            </not>
        </condition>
    </fail>
    <property environment="env"/>
    <property name="have.sources" value="true"/>
    <condition property="no.deps">
        <istrue value="${no.dependencies}"/>
    </condition>
    <target name="-pre-init">
        <condition property="manifest.available">
            <available file="${manifest.file}"/>
        </condition>
    </target>
    <target name="-do-init" depends="-pre-init">
        <condition property="main.class.available">
            <and>
                <isset property="main.class"/>
                <not>
                    <equals arg1="${main.class}" arg2="" trim="true"/>
                </not>
            </and>
        </condition>
        <property name="excludes" value=""/>
        <property name="includes" value="**"/>
        <property name="source.encoding" value="${source.encoding}"/>
        <condition property="src.dir" value="${src.dir}">
            <available file="${src.dir}" type="dir"/>
        </condition>
        <property name="build.classes.dir" location="${build.dir}/classes"/>
        <mkdir dir="${build.classes.dir}"/>
        <path id="javac.classpath"/>
        <pathconvert property="run.classpath" refid="javac.classpath"/>
        <pathconvert property="run.classpath.without.build.classes.dir" refid="javac.classpath"/>
    </target>
    <target name="-init-macrodef-javac">
        <macrodef name="javac" uri="http://www.netbeans.org/ns/j2se-project/3">
            <attribute default="${src.dir}" name="srcdir"/>
            <attribute default="${build.classes.dir}" name="destdir"/>
            <attribute default="${javac.classpath}" name="classpath"/>
            <attribute default="${includes}" name="includes"/>
            <attribute default="${excludes}" name="excludes"/>
            <sequential>
                <javac srcdir="@{srcdir}" destdir="@{destdir}" source="${javac.source}" target="${javac.target}"
                       includeantruntime="false" encoding="${source.encoding}" debug="true" debuglevel="lines,vars,source">
                    <classpath refid="javac.classpath"/>
                    <include name="@{includes}"/>
                    <exclude name="@{excludes}"/>
                </javac>
            </sequential>
        </macrodef>
    </target>
    <target name="-post-init"/>
    <target name="-init-check" depends="-pre-init,-do-init,-post-init"/>
    <target name="-init-macrodef-property"/>
    <target name="-init-macrodef-javac"/>
    <target name="-init-macrodef-junit"/>
    <target name="-init-macrodef-nbjpda"/>
    <target name="-init-macrodef-debug"/>
    <target name="-init-macrodef-java">
        <macrodef name="java" uri="http://www.netbeans.org/ns/j2se-project/1">
            <attribute default="${main.class}" name="classname"/>
            <element name="customize" optional="true"/>
            <sequential>
                <java classname="@{classname}" dir="${work.dir}" fork="true" failonerror="true">
                    <jvmarg line="${endorsed.classpath.cmd.line.arg}"/>
                    <jvmarg line="${run.jvmargs}"/>
                    <classpath>
                        <pathelement location="${build.classes.dir}"/>
                        <path refid="javac.classpath"/>
                    </classpath>
                    <customize/>
                </java>
            </sequential>
        </macrodef>
    </target>
    <target name="-init-presetdef-jar">
        <presetdef name="jar" uri="http://www.netbeans.org/ns/j2se-project/1">
            <jar compress="${jar.compress}">
                <fileset dir="${build.classes.dir}" excludes="${dist.archive.excludes}"/>
                <manifest>
                    <attribute name="Main-Class" value="${main.class}"/>
                </manifest>
            </jar>
        </presetdef>
    </target>
    <target depends="-pre-init,-do-init,-post-init,-init-check" name="init"/>
    <target depends="init,-init-macrodef-javac" name="-javac-compile">
        <javac srcdir="${src.dir}" destdir="${build.classes.dir}" includes="${includes}" excludes="${excludes}"/>
    </target>
    <target name="-compile" depends="init,-javac-compile"/>
    <target depends="init,-compile" name="compile"/>
    <target name="-pre-dist"/>
    <target depends="init,compile,-pre-dist" name="-do-dist">
        <mkdir dir="${dist.dir}"/>
        <jar jarfile="${dist.jar}" compress="${jar.compress}" basedir="${build.classes.dir}">
            <manifest>
                <attribute name="Main-Class" value="${main.class}"/>
            </manifest>
        </jar>
    </target>
    <target name="-post-dist"/>
    <target depends="init,compile,-pre-dist,-do-dist,-post-dist" name="dist"/>
    <target depends="init,compile" name="-do-run">
        <java classname="${main.class}" fork="true" failonerror="true">
            <classpath>
                <pathelement location="${build.classes.dir}"/>
            </classpath>
        </java>
    </target>
    <target depends="init,compile,-do-run" name="run"/>
    <target depends="init,compile" description="Clean and build." name="clean">
        <delete dir="${build.dir}"/>
    </target>
    <target name="default" depends="init,compile" description="Build the project."/>
</project>
